{
  "name": "NwAuthUser",
  "type": "object",
  "title": "Nightwatch Auth User",
  "description": "NW-UPGRADE-076A: Nightwatch-controlled user; email unique, password_hash never exposed.",
  "properties": {
    "email": { "type": "string", "format": "email" },
    "password_hash": { "type": "string" },
    "full_name": { "type": "string" },
    "role": {
      "type": "string",
      "enum": ["admin", "super_admin", "compliance_admin", "analyst", "reviewer", "viewer", "test_automation"]
    },
    "org_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "active", "disabled"]
    },
    "mfa_enabled": { "type": "boolean", "default": false },
    "mfa_secret": { "type": "string" },
    "oauth_provider": { "type": "string" },
    "oauth_provider_id": { "type": "string" },
    "created_by": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "last_login_at": { "type": "string", "format": "date-time" },
    "password_changed_at": { "type": "string", "format": "date-time" },
    "failed_login_count": { "type": "number", "default": 0 },
    "locked_until": { "type": "string", "format": "date-time" },
    "session_version": { "type": "number", "default": 0 }
  },
  "required": ["email", "role", "status"]
}
