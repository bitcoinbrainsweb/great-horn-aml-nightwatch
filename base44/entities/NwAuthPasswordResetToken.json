{
  "name": "NwAuthPasswordResetToken",
  "type": "object",
  "title": "Nightwatch Auth Password Reset Token",
  "description": "NW-UPGRADE-076A: Password reset token; token_hash only, no plaintext.",
  "properties": {
    "user_id": { "type": "string" },
    "token_hash": { "type": "string" },
    "expires_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "used_at": { "type": "string", "format": "date-time" },
    "ip_address": { "type": "string" }
  },
  "required": ["user_id", "token_hash", "expires_at"]
}
